{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "framework": "vite",
  "functions": {
    "dist/boot.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/dist/boot.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
